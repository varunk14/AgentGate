# AgentGate environment (copy to .env; .env is git-ignored)
# LLM provider is model-agnostic via LiteLLM. Set the model and its key.
AGENTGATE_LLM_MODEL=gemini/gemini-1.5-flash
GEMINI_API_KEY=your-key-here

# Fallbacks (optional)
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# Duplicate store (optional). Default is in-memory; set a file path to persist
# approvals across restarts. /verify only READS this store — recording an
# approval is a separate post-payment call, never a side effect of a decision.
# AGENTGATE_DB_PATH=agentgate.db

# System of record for fetch mode (optional). A directory of *.json invoice
# records; a request with source {"fetch": "INV-001"} resolves the record from
# here instead of accepting caller evidence — the agent chooses WHICH invoice,
# never what it says. Records are keyed by the invoice_number INSIDE each file
# (filenames are irrelevant) and validated like caller input. Unset = fetch
# requests fail closed to escalate.
# AGENTGATE_RECORDS_DIR=data/system_of_record

# Cross-origin access for the browser dashboard (optional). Comma-separated
# EXACT origins (scheme+host+port; localhost and 127.0.0.1 differ). Unset or
# empty = no cross-origin access at all — never "*".
# AGENTGATE_CORS_ORIGINS=http://127.0.0.1:3000

# Langfuse tracing (optional; requires `pip install -e ".[tracing]"`).
# Without both keys, tracing is a clean no-op and the service runs identically.
# A tracing failure never affects a decision.
# NOTE: keys are region-bound. Set LANGFUSE_HOST to the region in your
# Langfuse browser URL (cloud.langfuse.com = EU, us.cloud.langfuse.com,
# jp.cloud.langfuse.com); the SDK defaults to the EU host, and a region
# mismatch fails silently in the tracing layer (decisions are unaffected).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
