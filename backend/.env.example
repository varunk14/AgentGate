# AgentGate environment (copy to .env; .env is git-ignored)
# LLM provider is model-agnostic via LiteLLM. Set the model and its key.
AGENTGATE_LLM_MODEL=gemini/gemini-1.5-flash
GEMINI_API_KEY=your-key-here

# Fallbacks (optional)
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# Duplicate store (optional). Default is in-memory; set a file path to persist
# approvals across restarts. /verify only READS this store — recording an
# approval is a separate post-payment call, never a side effect of a decision.
# AGENTGATE_DB_PATH=agentgate.db

# Langfuse tracing (optional; requires `pip install -e ".[tracing]"`).
# Without both keys, tracing is a clean no-op and the service runs identically.
# A tracing failure never affects a decision.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
